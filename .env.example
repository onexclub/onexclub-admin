# Copy to `.env.local` (gitignored) and paste real values from Supabase → Project Settings → API.
# Never commit `.env`, `.env.local`, or any file with live keys.

# Public — bundled / visible in the browser; use the anon key only
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-only — NEVER prefix with NEXT_PUBLIC_
# Used for Auth Admin API (e.g. createUser) from Server Actions after authz checks.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Canonical site origin for password-reset redirects when headers are not enough (production).
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend (transactional email — gym owner / customer welcome; see src/lib/email/send-welcome-emails.ts)
# Use a bare address OR one display name — code normalizes via src/lib/email/resend-from-address.ts
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM_EMAIL=hello@email.onexclub.in
# RESEND_FROM_EMAIL=One X Club <hello@email.onexclub.in>

# OPTIONAL: support inbox shown in gym-owner welcome template (defaults to support@gymplatform.com).
# SUPPORT_EMAIL=support@your-domain.com

# Member app deep link / store listing (optional — customer welcome uses onexclub.in while app is pre-launch).
# APP_DOWNLOAD_URL=https://...
# ONEXCLUB_WEBSITE_URL=https://onexclub.in

# Internal-only API routes (Edge Function webhook → POST /api/send-customer-welcome).
# INTERNAL_API_KEY=generate-a-long-random-string

# MSG91 — Edge Functions `send-otp` / `verify-otp` (set via `supabase secrets set`, not NEXT_PUBLIC_)
# MSG91_AUTH_KEY=your_msg91_authkey
# MSG91_FLOW_ID=your_msg91_otp_template_or_flow_id

# Plan matching LLM — personalized plan generation + match validation
# Vendor-agnostic OpenAI-compatible API (Groq default). See src/lib/plans/template-matching/llm/
# PLAN_LLM_PROVIDER=groq
# PLAN_LLM_API_KEY=your_key
# PLAN_LLM_MODEL=llama-3.3-70b-versatile
# Legacy alias still works:
# GROQ_API_KEY=gsk_xxxxxxxxxxxx
# OpenAI example:
# PLAN_LLM_PROVIDER=openai
# PLAN_LLM_API_KEY=sk-...
# PLAN_LLM_MODEL=gpt-4o-mini
